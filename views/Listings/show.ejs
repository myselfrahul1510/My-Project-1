<% layout("/layouts/boilerplate.ejs") -%>
<script>
    let mapToken = "<%= process.env.MAP_TOKEN %>";
    let listing =  <%- JSON.stringify(listItem) %>
</script>

    <div class="row">
        <div class="col-8 offset-3 mt-3">
            <h1>
                <%= listItem.title %>
            </h1>
        </div>
        <div class=" card listing-card col-6 offset-3 show-card">
            <img src="<%= listItem.Image.url %>" class="card-img-top show-img" alt="Listing Image">
            <div class="card-body">
                <p class="card-text">
                    <i> Owned by: <%= listItem.owner.username %></i><br>
                    <%= listItem.description %> <br>
                        &#8377;<%= listItem.price.toLocaleString("en-IN")%> <br>
                            <%= listItem.location %> <br>
                                <%= listItem.country %>
                </p>
            </div>
        </div>
    </div>
    <%if (currUser && currUser._id.equals(listItem.owner._id)) { %>
        <div class="btns">
            <a href="/listings/<%= listItem._id %>/edit" class="btn btn-dark offset-3 edit-btn mb-3">Edit</a>
            <form method="post" action="/listings/<%= listItem._id %>?_method=Delete">
                <Button class="btn btn-dark offset-5 mb-3">Delete</Button>
            </form>
        </div>

        <% } %>

            <div class="row">
                <div class="col-8 offset-3 mt-3 mb-3">
                    <% if (currUser) {%>
                        <hr>
                        <h4>
                            Leave a Review
                        </h4>
                        <form method="post" action="/listings/<%= listItem._id %>/reviews" novalidate
                            class="needs-validation">
                            <div class="mb-3 mt-3">
                                <!-- Rating star implementing  -->
                                <label for="rating" class="form-label"> Rating </label>
                                <fieldset class="starability-growRotate">
                                    <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]"
                                        value="1" checked aria-label="No rating." />
                                    <input type="radio" id="rate1" name="review[rating]" value="1" />
                                    <label for="rate1" title="Terrible">1 star</label>
                                    <input type="radio" id="rate2" name="review[rating]" value="2" />
                                    <label for="rate2" title="Not good">2 stars</label>
                                    <input type="radio" id="rate3" name="review[rating]" value="3" />
                                    <label for="rate3" title="Average">3 stars</label>
                                    <input type="radio" id="rate4" name="review[rating]" value="4" />
                                    <label for="rate4" title="Very good">4 stars</label>
                                    <input type="radio" id="rate5" name="review[rating]" value="5" />
                                    <label for="rate5" title="Amazing">5 stars</label>
                                </fieldset>
                            </div>

                            <div class="mb-3 mt-3">
                                <label for="comment" class="form-label">Comments</label>
                                <textarea name="review[comment]" id="comment" cols="30" rows="5" class="form-control"
                                    required></textarea>
                                <div class="invalid-feedback">Please Submit some Comments for review</div>
                            </div>

                            <div>
                                <button type="submit" class="btn btn-outline-dark">Submit</button>
                            </div>
                        </form>
                        <% } %>
                            <hr>
                            <!-- delete the review -->
                            <% if(listItem.reviews.length> 0) { %>
                                <div class="row">
                                    <h4 class="mb-3"> All Review </h4>
                                    <% for (review of listItem.reviews) { %>
                                        <div class="card col-5 ms-3 mb-3 p-2">
                                            <div class="card-body">
                                                <h5 class="card-title">
                                                    @ <%= review.author.username %>
                                                </h5>
                                                <p class="card-text">
                                                    <%= review.comment %>
                                                </p>
                                                <p class="card-text starability-result"
                                                    data-rating="<%= review.rating %>">
                                                    Rated: 3 stars
                                                </p>

                                            </div>
                                            <% if(currUser && review.author._id.equals(currUser._id)) { %>
                                                <!-- Ei condition ta ami nijer theke lagiyechi j account theke login setar ei review te shudhu delete button thakbe onno guloi thakbe naa , r eitar jonno pore kono problem hole uriye dio. -->
                                                <form method="post"
                                                    action="/listings/<%= listItem._id %>/reviews/<%= review._id %>?_method=DELETE">
                                                    <button class="btn btn-dark mt-3">Delete</button>
                                                </form>
                                                <% } %>
                                        </div>
                                        <% } %>

                                </div>
                                <hr>
                                <% } %>
                </div>
                <DIV class="col-8 offset-3 mb-3">
                    <h3> Where you'll be</h3>
                    <div id="map"></div>
                </DIV>
            </div>

<script src="/js/map.js"></script>